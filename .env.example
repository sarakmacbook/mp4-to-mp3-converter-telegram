# Get from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Railway auto-sets PORT, but you can override
PORT=8080

# For webhook mode on Railway:
# 1. Deploy first without this (uses polling)
# 2. Get your Railway domain from Settings > Domains
# 3. Set WEBHOOK_URL=https://your-app.railway.app
# 4. Redeploy
WEBHOOK_URL=
